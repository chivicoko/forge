# Timeouts for slower connections
fetch-timeout=300000
fetch-retry-maxtimeout=300000
fetch-retry-mintimeout=10000
fetch-retries=5

# Allow build scripts for these packages (silences ERR_PNPM_IGNORED_BUILDS)
only-built-dependencies[]=@clerk/shared
only-built-dependencies[]=sharp
only-built-dependencies[]=unrs-resolver
